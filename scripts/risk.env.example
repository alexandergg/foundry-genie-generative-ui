# Copy to .risk.env.local or export these values in your shell.
# Do not commit .risk.env.local or any token values.

# Azure control plane
export AZURE_SUBSCRIPTION_ID="<subscription-id>"
export AZURE_TENANT_ID="<tenant-id>"
export LOCATION="westeurope"
export RESOURCE_GROUP="rg-risk-exposure-genui-foundry-demo"

# Existing Databricks workspace reused by infra/main.demo.bicepparam.
export DATABRICKS_WORKSPACE_NAME="<existing-databricks-workspace-name>"
export DATABRICKS_HOST="https://<workspace-host>.azuredatabricks.net"

# Optional: leave unset to let scripts request an Azure CLI token for Databricks.
# export DATABRICKS_TOKEN="<databricks-pat-or-aad-token>"

# SQL warehouse and data scope
export WAREHOUSE_NAME="Risk Exposure Genie Demo 2X-Small"
export WAREHOUSE_SIZE="2X-Small"
export WAREHOUSE_AUTO_STOP_MINUTES="10"
export WAREHOUSE_ID="<set-after-creating-or-listing-warehouse>"
export DEMO_CATALOG="<workspace-default-catalog-or-custom-catalog>"
export DEMO_SCHEMA="default"
export DEMO_VIEW_NAME="vw_risk_genie_exposure_claims"

# Genie
export GENIE_SPACE_TITLE="Risk Exposure Genie Demo"
export GENIE_SPACE_DESCRIPTION="Genie Space for conversational analytics over synthetic exposure, overdue balance, claims, and broker data for the Risk Exposure Generative UI demo."
export GENIE_SPACE_ID="<set-after-creating-genie-space>"

# Foundry project and agent. deploy-infra.sh now outputs these Foundry values.
export FOUNDRY_PROJECT_ENDPOINT="https://<foundry-resource>.services.ai.azure.com/api/projects/<project-name>"
export FOUNDRY_PROJECT_RESOURCE_ID="/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>"
export FOUNDRY_GENIE_CONNECTION_NAME="databricks-genie-risk-mcp"
export FOUNDRY_GENIE_AGENT_NAME="risk-exposure-genie-agent"
# Optional: override the prompt template used by setup-foundry-genie-agent.sh.
# export FOUNDRY_GENIE_PROMPT_TEMPLATE="scripts/foundry-genie-agent-instructions.txt"
export FOUNDRY_MODEL_DEPLOYMENT="gpt-5-4"

# Optional outputs from infra for hosted-agent deployment and telemetry.
# export AZURE_CLIENT_ID="<runtime-user-assigned-managed-identity-client-id>"
# export AZURE_CONTAINER_REGISTRY_NAME="<acr-name>"
# export AZURE_CONTAINER_REGISTRY_LOGIN_SERVER="<acr-login-server>"
# export FOUNDRY_HOSTED_AGENT_IMAGE_REPOSITORY="risk-exposure-ag-ui-hosted"
# export APPLICATIONINSIGHTS_RESOURCE_ID="/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Insights/components/<app-insights-name>"
# export APPLICATIONINSIGHTS_CONNECTION_STRING="<app-insights-connection-string>"
# export KEY_VAULT_URI="https://<key-vault-name>.vault.azure.net/"

# Optional outputs when a per-band frontend is deployed (deployControlledFrontend /
# deployDeclarativeFrontend / deployOpenEndedFrontend = true in infra/main.demo.bicepparam).
# export FRONTEND_WEB_APP_NAME="<frontend-web-app-name>"
# export FRONTEND_WEB_APP_URL="https://<frontend-web-app-name>.azurewebsites.net"
