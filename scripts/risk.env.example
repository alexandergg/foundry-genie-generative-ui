# Copy to .risk.env.local or export these values in your shell.
# Do not commit .risk.env.local or any token values.

# Azure control plane
export AZURE_SUBSCRIPTION_ID="<subscription-id>"
export AZURE_TENANT_ID="<tenant-id>"
export LOCATION="westeurope"
export RESOURCE_GROUP="rg-risk-exposure-genui-demo"

# Databricks workspace created by infra/main.bicep
export DATABRICKS_WORKSPACE_NAME="<databricks-workspace-name>"
export DATABRICKS_HOST="https://<adb-workspace-id>.<region-code>.azuredatabricks.net"

# Optional: leave unset to let scripts request an Azure CLI token for Databricks.
# export DATABRICKS_TOKEN="<databricks-pat-or-aad-token>"

# SQL warehouse and data scope
export WAREHOUSE_NAME="Risk Exposure Genie Demo 2X-Small"
export WAREHOUSE_SIZE="2X-Small"
export WAREHOUSE_AUTO_STOP_MINUTES="10"
export WAREHOUSE_ID="<set-after-creating-or-listing-warehouse>"
export DEMO_CATALOG="<workspace-default-catalog-or-custom-catalog>"
export DEMO_SCHEMA="default"
export DEMO_VIEW_NAME="vw_risk_genie_exposure_claims"

# Genie
export GENIE_SPACE_TITLE="Risk Exposure Genie Demo"
export GENIE_SPACE_DESCRIPTION="Genie Space for conversational analytics over synthetic exposure, overdue balance, claims, and broker data for the Risk Exposure Generative UI demo."
export GENIE_SPACE_ID="<set-after-creating-genie-space>"

# Foundry project and agent
export FOUNDRY_PROJECT_ENDPOINT="https://<foundry-resource>.services.ai.azure.com/api/projects/<project-name>"
export FOUNDRY_PROJECT_RESOURCE_ID="/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>/projects/<project>"
export FOUNDRY_GENIE_CONNECTION_NAME="databricks-genie-risk-mcp"
export FOUNDRY_GENIE_AGENT_NAME="risk-exposure-genie-agent"
export FOUNDRY_MODEL_DEPLOYMENT="gpt-4.1-mini"
