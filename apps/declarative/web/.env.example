# Declarative agent endpoint used by /api/copilotkit.
# Local bridge by default; point at a Foundry Hosted Agent invocations endpoint
# and set AG_UI_AGENT_AUTH=azure-identity to use the hosted runtime instead.
AG_UI_AGENT_URL=http://localhost:8124
AG_UI_AGENT_AUTH=
AG_UI_AGENT_SCOPE=https://ai.azure.com/.default

# Spectrum nav targets (build-time, NEXT_PUBLIC_*). Leave empty for localhost;
# set to the deployed URLs when building for Azure.
NEXT_PUBLIC_SPECTRUM_URL_CONTROLLED=
NEXT_PUBLIC_SPECTRUM_URL_DECLARATIVE=
NEXT_PUBLIC_SPECTRUM_URL_OPEN_ENDED=
