# Azure AI Foundry model endpoint (OpenAI-compatible), e.g.
# https://<resource>.services.ai.azure.com/openai/v1
# RISK_MODEL_* are the primary names (FOUNDRY_* is reserved inside hosted-agent
# containers); FOUNDRY_MODEL_* / AZURE_AI_MODEL_* keep working as fallbacks.
RISK_MODEL_ENDPOINT=
# Model deployment name. Prefer a strong deployment (gpt-4o or better).
RISK_MODEL_DEPLOYMENT=gpt-4o
# Optional API key. Leave empty to use DefaultAzureCredential (az login).
RISK_MODEL_API_KEY=

PORT=8124
