# Backend AG-UI endpoint used by /api/copilotkit.
# Prefer AG_UI_AGENT_URL; LANGGRAPH_DEPLOYMENT_URL remains as a backward-compatible fallback.
AG_UI_AGENT_URL=http://localhost:8123
LANGGRAPH_DEPLOYMENT_URL=http://localhost:8123

# Set to azure-identity when AG_UI_AGENT_URL points to a Foundry Hosted Agent Invocations endpoint.
AG_UI_AGENT_AUTH=
AG_UI_AGENT_SCOPE=https://ai.azure.com/.default

# Optional local rate limit for /api/copilotkit
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=40
