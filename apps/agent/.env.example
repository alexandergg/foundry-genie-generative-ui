# Optional: if unset, the backend reads .foundry/agent-metadata.yaml at the repository root.
# You can also point to a custom metadata file with FOUNDRY_METADATA_PATH.
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_AGENT_NAME=risk-exposure-genie-agent
FOUNDRY_AGENT_VERSION=risk-exposure-genie-agent:3

# Azure auth uses DefaultAzureCredential. For local demos, run: az login
AZURE_TENANT_ID=

# Human-in-the-loop data access gate before calling Foundry/Genie
FOUNDRY_REQUIRE_HUMAN_DATA_APPROVAL=true

# Internal MCP approvals after the user has approved data access
FOUNDRY_MCP_APPROVAL_ROUNDS=20

# Retry if Genie temporarily reports that the warehouse/query is still warming up or pending
FOUNDRY_TRANSIENT_RESPONSE_RETRIES=2

# Server
PORT=8123

# Foundry Hosted Agent Invocations local runs use FOUNDRY_PROJECT_ENDPOINT and listen on port 8088.
# APPLICATIONINSIGHTS_CONNECTION_STRING is injected by hosted Foundry containers; do not commit local values.
